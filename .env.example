# LLM API
OPENAI_API_KEY=sk-your-openai-api-key-here

# PostgreSQL
POSTGRES_USER=scider
POSTGRES_PASSWORD=scider_dev_password
POSTGRES_DB=scider_rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://scider:scider_dev_password@postgres:5432/scider_rag

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=scider_chunks

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Ingestion
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# LLM Settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=30

# Agent Settings
AGENT_MAX_ITERATIONS=5
RETRIEVAL_TOP_K=10

# OCR / Vision (for scanned PDFs and image analysis)
ENABLE_OCR=true
ENABLE_IMAGE_ANALYSIS=true
OCR_MODEL=gpt-4o-mini
MAX_OCR_PAGES=50

# Code Execution Sandbox
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MAX_MEMORY_MB=256
